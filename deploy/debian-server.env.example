# Debian VPS wgmesh server template settings.
#
# Copy to /opt/wgmesh/server.env and edit:
#   cp deploy/debian-server.env.example /opt/wgmesh/server.env

# Published by the Gitea Actions workflow.
WGMESH_SERVER_IMAGE=gitea.mynetbird.uk/YOUR_OWNER/wgmesh-server:latest

# Public HTTPS hostname routed by Traefik to this container.
WGMESH_HOST=mesh.mynetbird.uk

# Persistent state: mesh.db, mesh-psk.key, admin-token.
WGMESH_DATA_DIR=/opt/wgmesh/server

# During migration you can match your old WireGuard range, e.g.
# WGMESH_NETWORK=100.78.0.0/21
# WGMESH_NETWORK6=fd32:d2ad:be4f::/64
WGMESH_NETWORK=100.64.0.0/16
WGMESH_NETWORK6=fd00:100:64::/64

# deny = segmented mesh until ACL rules connect peers.
WGMESH_DEFAULT_POLICY=deny

# 720h = 30 days. Agents re-enroll to rotate tokens.
WGMESH_TOKEN_TTL=720h

# memory = UI/API ring buffer, stdout = JSONL, off = disabled.
WGMESH_ACCESS_LOG=memory

# DNS can also be configured later in the Web UI under Settings -> DNS.
# If you want first-start defaults, add these flags to the compose command:
#   --dns-enabled
#   --dns-nameservers 100.78.0.1
#   --dns-domain vpn
# Use the IP where agents can reach your existing CoreDNS service.

# Existing Traefik file-provider middlewares. Leave blank to attach none:
# WGMESH_TRAEFIK_MIDDLEWARES=
WGMESH_TRAEFIK_MIDDLEWARES=crowdsec@file
