// Windows resources for agent.exe / agent-gui.exe: the executable's
// icon and the version block Explorer and Task Manager display.
//
// Compiled into ../resource_windows_amd64.syso (which the Go linker
// picks up automatically for windows/amd64 builds of cmd/agent) with:
//
//   deploy/gen-winres.sh
//
// Regenerate only when this file or agent.ico changes; the .syso is
// checked in so normal builds need no windres.

1 ICON "agent.ico"

1 VERSIONINFO
FILEVERSION     0,1,0,0
PRODUCTVERSION  0,1,0,0
FILEOS          0x40004L
FILETYPE        0x1L
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "FileDescription", "wgmesh Agent"
      VALUE "ProductName", "wgmesh"
      VALUE "InternalName", "wgmesh-agent"
      VALUE "OriginalFilename", "agent.exe"
      VALUE "FileVersion", "0.1.0"
      VALUE "ProductVersion", "0.1.0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x409, 1200
  END
END
